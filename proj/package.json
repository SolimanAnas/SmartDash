{
  "name": "dcas-airport-ops",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "DCAS Airport Operations Platform - modular source, single-file build",
  "scripts": {
    "icons": "node scripts/generate-icons.mjs",
    "build": "npm run icons && node build.mjs",
    "lint": "eslint src/",
